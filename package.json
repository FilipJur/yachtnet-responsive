{
  "name": "yachtnet-responsive",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run css:build && concurrently \"npm run css:watch\" \"npm run serve\"",
    "serve": "live-server --port=3000 --open=\"index.html\" --watch=\"css,*.html\"",
    "css:build": "lightningcss --minify --bundle src/css/main.css -o css/responsive-mobile.css",
    "css:watch": "chokidar \"src/css/**/*.css\" -c \"npm run css:build\""
  },
  "devDependencies": {
    "chokidar": "^5.0.0",
    "concurrently": "^8.2.2",
    "lightningcss-cli": "^1.24.1",
    "live-server": "^1.2.2"
  }
}
