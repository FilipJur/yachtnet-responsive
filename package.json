{
  "name": "yachtnet-responsive",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run css:build && concurrently \"npm run css:watch\" \"npm run serve\"",
    "serve": "browser-sync start --server --port 3000 --startPath \"index.html\" --files \"css/*.css,*.html\" --no-notify",
    "css:build": "lightningcss --minify --bundle --sourcemap src/css/main.css -o css/responsive-mobile.css && bash fix-sourcemap.sh",
    "css:watch": "nodemon --watch src/css --ext css --delay 0.5 --exec \"npm run css:build\""
  },
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "concurrently": "^8.2.2",
    "lightningcss-cli": "^1.24.1",
    "nodemon": "^3.1.14"
  }
}
