# macOS
.DS_Store
**/.DS_Store

# Cache
cache/

# Logs
*.log

# Images (downloaded from site, not source code)
# Ignore all images by default
img/
ext/img/

# Critical UI images - referenced in CSS/HTML (unignore)
!img/claim*.jpg
!img/icon-sprite*.png
!img/hp-banner-sprite*.jpg
!img/star-sprite*.png
!img/courses-*.jpg
!img/favicon.ico
!img/logo.svg
!img/apple-icon*.png
!img/iso_cz2022.jpg
!img/helena.jpg
!img/hitt.jpg
!img/scales.png
!img/yp_checked2026.png
!img/martin.jpg
!img/monika.jpg
!img/petrak.jpg
!img/jarmila.jpg
!img/marta.jpg

# Responsive background images (crucial for CSS)
!img/responsive/bg-*.jpg

# Documents and binary files
*.pdf
doc/

# External dependencies (if we add Node.js tooling later)
node_modules/

# Build artifacts (if we add a build process)
dist/
build/

# IDE files
.vscode/
.idea/
.zed/
*.swp
*.swo
*~

# Editor backup files
*.bak
*.orig

# Temporary files
.tmp/
temp/

# Archives and compressed files
*.zip
*.tar.gz
*.rar
*.7z

# Source maps (if generated during build)
*.map

# Local environment files
.env
.env.local
.env.*.local

# SiteSucker metadata
_downloads.html

# Query parameter files (search results with filters)
# Standard question mark
*\?from=*
*\?page=*
*\?destination=*
*\?sortb=*
# Unicode full-width question mark variants
*﹖from=*
*﹖page=*
*﹖destination=*
*﹖sortb=*
# Generic query parameter patterns (covers any query string)
*\?*

# Keep directory structure but ignore contents for some folders
# (uncomment if needed)
# chartrovky/*
# clenstvi-a-certifikaty/*
# ext/*

# OpenCode editor configuration
.opencode/

# Research and analysis files
kimi-analysis/

# Screenshots (generated)
screenshots/

# Generated CSS (built from src/css/)
# NOTE: We commit the built CSS for Netlify deployment
# css/responsive-mobile.css
